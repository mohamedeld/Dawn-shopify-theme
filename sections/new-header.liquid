{% style %}
  body:not(.index) .top-new-header {
    border-bottom: 1px solid #eee;
  }
  .new-header {
    display: flex;
    justify-content: space-between;
    gap: 1em;
    align-items: center;
    padding: 1em 0;
  }
  .new-header img {
    object-fit: cover;
    max-width: 120px;
    width: 100%;
    height: auto;
  }
  .toggle-sidecart {
    position: relative;
  }
  a.logo {
    text-align: center;


  }
  a.logo img {
    max-width: 120px;
    width: 100%;
    height: 50px;
  }
  .search form {
    position: relative;
    border: 1px solid #eee;
    border-radius: 40px;
    overflow: hidden;

  }
  .search input {
    width: 100%;
    padding: 0.5em 0.5em 0.5em 1.5em;
    background: #f5f5f5;
    border: transparent;

  }
  .search button.search-header__submit {
    position: absolute;
    cursor: pointer;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    top: 50%;
    transform: translateY(-50%);
    right: 2%;
    background: #333;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .new-header .icons {
    display: grid;
    grid-auto-flow: column;
    justify-content: flex-end;
    align-items: center;
    gap: 1.5em;
  }
  .new-header .icons a.account-icon img {
    width: 24px;
    height: 24px;
  }
  .new-header .icons a.cart img {
    width: 24px;
    height: 24px;
  }
  .js-cartcount {
    background: #333;
    color: #fff;
    width: 14px;
    height: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    border-radius: 50%;
    position: absolute;
    right: -0.5em;
    top: 0;
  }
  .logo-menu {
    display: flex;
    align-items: center;
    gap: 1em;
    max-width: 530px;
    width: 100%;
  }
  .logo-menu a {
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: #000;

  }
  .logo-menu .links {
    display: flex;
    align-items: center;
    gap: 1em;
  }
  .icons a {
    text-decoration: none;
    color: #000;
  }
  .new-header .search {
    position: relative;
    z-index: 2;
    max-width: 348px;
    width: 100%;
  }

  .new-header .search #searchResults {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background: #fff;
    border: 1px solid #eee;
    border-top: none;
    z-index: 2;
    box-shadow: 0 0 5px rgba(0, 0, 0, 0.25);
  }
  .result-heading {
    padding: 2em 0;
    text-align: center;
  }
  .new-header .search #searchResults:empty {
    display: none;
  }
  .new-header .search #searchResults p.no-results {
    padding: 1em 1em 0.5em;
  }
  .top-new-header input#searchInput:focus-visible {
    outline: none;
    box-shadow: none;
  }
  #searchResults .product-card {
    display: flex;
    justify-content: flex-start;
    padding: 1em;
  }
  #searchResults .product-card:not(:last-of-type) {
    border-bottom: 1px solid #eee;
  }
  #searchResults .product-card:last-of-type {
    padding-bottom: 0.5em;
  }
  #searchResults .product-card img {
    width: 70px;
    height: 70px;
    object-fit: cover;
  }
  #searchResults .grid-content {
    display: flex;
    flex-flow: column;
    gap: 4px;
    align-items: flex-start;
    text-align: left;
  }
  #searchResults .collection-price {
    justify-content: flex-start;
  }
  #searchResults p {
    margin: 0 0 4px;
    font-weight: 600
  }

{% endstyle %}

<div class="container">
  <div class="new-header">
    <div class="logo-menu">
      <a href="{{shop.url}}" class="logo">
        <img src="{{ section.settings.logo | image_url }}" alt="{{ shop.name }}" />
      </a>
      <div class="links">
        {% for block in section.blocks %}
          <a href="{{ block.settings.linkUrl }}">{{ block.settings.name }}</a>
        {% endfor %}
      </div>
    </div>
    <div class="search">
      <form
        action="/search"
        method="get"
        role="search"
        id="search-form">
        <input
          type="search"
          name="q"
          id="search-input"
          aria-label="search our site"
          placeholder="Search"
          class="search-header__input" />
        <button type="submit" class="search-header__submit">
          <img
            src="{{ 'search-icon.png' | asset_url }}"
            alt="Search"
            class="search-header__icon" />
        </button>
      </form>
      <div id="searchResults"></div>
    </div>
    <div class="icons">
      <a href="/account/login" class="account-icon">
        <img
          width="24"
          src="{{ 'user.png' | asset_url }}"
          alt="Account" />
      </a>
      <a href="/cart" class="cart toggle-sidecart">
        <span class="js-cartcount">{{ cart.item_count }}</span>
        <img
          width="24"
          src="{{ 'cart.png' | asset_url }}"
          alt="Cart" />
      </a>
    </div>
  </div>
</div>

{% schema %}
  {
    "name": "New Header",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      }
    ],
    "blocks": [
      {
        "type": "menu",
        "name": "Menu",
        "settings": [
          {
            "type": "text",
            "id": "name",
            "label": "Menu Name"
          }, {
            "type": "url",
            "id": "linkUrl",
            "label": "Link URL"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "New Header"
      }
    ]
  }
{% endschema %}